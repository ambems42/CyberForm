OPENAI_API_KEY=
JWT_SECRET=

CYBERFORM_APP_URL=http://localhost:4200

# CORS : liste séparée par des virgules, ou * (un avertissement est loggé). Vide = origines dev par défaut.
CORS_ORIGINS=

SHOW_ERROR_DETAILS=
FLASK_DEBUG=
# production : FLASK_ENV=production ou CYBERFORM_PRODUCTION=true active les contrôles au démarrage
CYBERFORM_PRODUCTION=
# si true avec CYBERFORM_PRODUCTION : arrêt au démarrage si une règle échoue
CYBERFORM_STRICT_PRODUCTION=

RATELIMIT_LOGIN=
RATELIMIT_REQUEST_RESET=
RATELIMIT_RESET_PASSWORD=
RATELIMIT_STORAGE_URI=

# SMTP (réinitialisation mot de passe, formulaire contact) — valeurs uniquement dans .env
# Gmail : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=votre@gmail.com
# SMTP_PASSWORD = mot de passe d'application (Compte Google → Sécurité → validation en 2 étapes → mots de passe des applications), pas le mot de passe du compte
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# En prod : true si l’app doit envoyer des e-mails (contrôle au démarrage : identifiants présents)
SMTP_REQUIRED=
# Boîte qui reçoit les messages du formulaire « Contact » (défaut : SMTP_FROM)

CONTACT_TO_EMAIL=

# Limite anti-spam sur POST /api/contact
RATELIMIT_CONTACT=

MONGO_URI=mongodb://localhost:27017/cyberform

# true derrière un reverse proxy de confiance (X-Forwarded-For pour le rate limit)
TRUST_PROXY=
# Nombre de proxies devant l’app (X-Forwarded-For : 1 = le premier hop)
TRUSTED_PROXY_COUNT=1

JWT_EXPIRE_HOURS=24

# JWT : cookie HttpOnly (recommandé) ; JSON body optionnel pour compat
USE_JWT_COOKIE=true
JWT_RETURN_BODY_TOKEN=false
JWT_COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# Production HTTPS : en-tête Strict-Transport-Security (désactivé en local)
HSTS_ENABLE=false
HSTS_MAX_AGE=31536000
